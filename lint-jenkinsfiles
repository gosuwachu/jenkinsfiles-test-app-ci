#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if ! command -v npx &>/dev/null; then
    echo "ERROR: npx not found. Install Node.js (apt-get install nodejs npm)."
    exit 1
fi

cd "$SCRIPT_DIR"

FILES=$(find . -name 'Jenkinsfile' -o -name '*.Jenkinsfile' | sort)
echo "=== npm-groovy-lint ==="
echo "Linting: $FILES"
exec npx npm-groovy-lint $FILES --failon warning
